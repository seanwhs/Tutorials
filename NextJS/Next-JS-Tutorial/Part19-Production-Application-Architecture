# Server Actions Architecture

Create:

```text
actions/

    posts.ts
    auth.ts
    comments.ts
```

---

Example:

```tsx
"use server";

export async function createPost(
    formData: FormData
) {

    await db.post.create({

        data: {

            title:
                String(
                    formData.get(
                        "title"
                    )
                ),

        },

    });

    revalidateTag(
        "posts"
    );

}
```

